{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "pytest memory cache",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/cache/memory",
                "-v"
            ]
        },
        {
            "name": "pytest redis cache",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/cache/redis",
                "-v"
            ]
        },
        {
            "name": "pytest memory datasrc cache",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/datasrc/cache/memory",
                "-v"
            ]
        },
        {
            "name": "pytest redis datasrc cache",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/datasrc/cache/redis",
                "-v"
            ]
        },
        {
            "name": "pytest semanticscholar datasrc",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/datasrc/semanticscholar",
                "-v"
            ],
            "env": {
                "SS_API_KEY": "your_api_key_here"
            }
        },
        {
            "name": "pytest dblp datasrc",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/datasrc/dblp",
                "-v"
            ]
        },
        {
            "name": "pytest crossref datasrc",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/datasrc/crossref",
                "-v"
            ]
        },
        {
            "name": "pytest arxiv datasrc",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/datasrc/arxiv",
                "-v"
            ]
        },
        {
            "name": "pytest neo4j datadst",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/datadst/neo4j",
                "-v"
            ]
        },
        {
            "name": "run dblp",
            "type": "debugpy",
            "request": "launch",
            "module": "paper_weaver",
            "args": [
                "-v",
                "--weaver-type=a2p2v",
                "--cache-mode=redis",
                "--cache-redis-url=redis://localhost:6379",
                "--datasrc-type=dblp",
                "--datasrc-cache-mode=redis",
                "--datasrc-redis-url=redis://localhost:6379",
                "--datadst-type=neo4j",
                "--max-iterations=3",
                "--init=dblp-venue-index",
                "--datasrc-max-concurrent=2",
                "--init-dblp-venue-index-keys",
                "db/conf/cvpr",
                "db/journals/pami",
            ],
            "justMyCode": false
        },
        {
            "name": "run crossref",
            "type": "debugpy",
            "request": "launch",
            "module": "paper_weaver",
            "args": [
                "-v",
                "--weaver-type=p2r2a",
                "--cache-mode=redis",
                "--cache-redis-url=redis://localhost:6379",
                "--datasrc-type=crossref",
                "--datasrc-cache-mode=redis",
                "--datasrc-redis-url=redis://localhost:6379",
                "--datadst-type=neo4j",
                "--max-iterations=3",
                "--init=crossref-neo4j-papers",
                "--datasrc-max-concurrent=2",
                "--init-crossref-neo4j-patterns",
                "MATCH (paper:Paper)-[:HAS_ID]->(id:PaperIdentifier) WHERE id.value STARTS WITH 'dblp:url:db/conf/cvpr'",
            ],
            "justMyCode": false
        },
        {
            "name": "run arxiv",
            "type": "debugpy",
            "request": "launch",
            "module": "paper_weaver",
            "args": [
                "-v",
                "--weaver-type=p-only",
                "--cache-mode=redis",
                "--cache-redis-url=redis://localhost:6379",
                "--datasrc-type=arxiv",
                "--datasrc-cache-mode=redis",
                "--datasrc-redis-url=redis://localhost:6379",
                "--datadst-type=neo4j",
                "--init=arxiv-query",
                "--init-arxiv-query",
                "cat:cs.CV&sortBy=lastUpdatedDate",
                "--init-arxiv-pages=2",
                "--init-arxiv-page-size=10",
            ],
            "justMyCode": false
        },
    ]
}